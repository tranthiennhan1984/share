 box_name: IPVN06_BATCH
 machine: sv84895
 owner: frpautp1@sv84895
 permission: gx,ge,wx,we
 date_conditions: 0
 condition: t(IPVN06_FW_SUNDAY.FLG)
 description: "watch for CLAIMS CLPFARED.DAT file in /JW/DLY folder cut-off time"
 term_run_time: 2
 alarm_if_fail: 0
 profile: "IPVN06"
 alarm_if_terminated: 1
