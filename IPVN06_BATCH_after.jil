

/* ----------------- IPVN06_BATCH ----------------- */ 

insert_job: IPVN06_BATCH   job_type: BOX 
owner: frpautp1@sv84895
permission: gx,ge,wx,we
date_conditions: 1
days_of_week: su,mo,tu,we,th,fr,sa
start_times: "23:00"
box_success: (s(IPVN06_RU_ASULRPT_CHECK) & s(IPVN06_BX_BKTAPE)) | (s(IPVN06_BX_SUNDAY) & s(IPVN06_FW_SUNDAY.FLG))
description: "Ingenium Vietnam Dayend Batch RITM0713234 CHG0075523"
alarm_if_fail: 1
alarm_if_terminated: 1


